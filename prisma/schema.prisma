// CRM + Invoicing — schema.
// Models added in each milestone; do not remove or rename existing fields without a migration plan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  USER
}

enum UserLocale {
  cs
  en
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  name               String
  role               UserRole   @default(USER)
  locale             UserLocale @default(cs)
  calendarColor      String     @default("#2563eb")
  signatureImagePath String?
  notificationPrefs  Json       @default("{}")
  deactivatedAt      DateTime?
  onboardingDoneAt   DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  invitesCreated     Invite[]             @relation("InviteCreator")
  passwordResets     PasswordResetToken[]
  auditLogs          AuditLog[]
  contactLogs        ContactLog[]
  jobAssignments     JobAssignment[]
  attachmentsUploaded Attachment[]        @relation("AttachmentUploader")
  calendarEventsCreated  CalendarEvent[]  @relation("CalendarEventCreator")
  calendarEventsAssigned CalendarEvent[]  @relation("CalendarEventAssignee")
  documentsCreated   Document[]           @relation("DocumentCreator")
  paymentsLogged     Payment[]
  expensesCreated    Expense[]            @relation("ExpenseCreator")
  recurrencesCreated RecurrenceRule[]     @relation("RecurrenceCreator")
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  tokenHash   String    @unique
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// One or more company profiles (branding/legal identity) per PRD §9.1.
model CompanyProfile {
  id                     String   @id @default(cuid())
  name                   String
  ico                    String?
  dic                    String?
  addressStreet          String?
  addressCity            String?
  addressZip             String?
  addressCountry         String   @default("CZ")
  iban                   String?
  swift                  String?
  accountNumber          String?
  logoPath               String?
  brandColor             String   @default("#1d4ed8")
  defaultHeaderText      String?
  defaultFooterText      String?
  defaultPaymentTermsDays Int     @default(14)
  defaultWarrantyText    String?
  isDefault              Boolean  @default(false)
  archivedAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  documentTemplates      DocumentTemplate[]
  documents              Document[]
}

// User-configurable VAT rates. Pre-filled: 21, 12, 0. Used by line items starting M6.
model TaxRate {
  id         String    @id @default(cuid())
  label      String
  percent    Decimal   @db.Decimal(5, 2)
  isDefault  Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  itemTemplates ItemTemplate[]

  @@unique([label])
}

// User-configurable item categories. Pre-filled: Labor, Materials, Travel, Diagnosis.
model ItemCategory {
  id         String    @id @default(cuid())
  name       String
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  itemTemplates ItemTemplate[]

  @@unique([name])
}

// Audit log — PRD §23. Every create/edit/delete on protected entities records actor + before/after.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  entity     String
  entityId   String
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId, createdAt])
}

// ──────────────────────────────────────────────────────────
// M3 — Client CRM (PRD §4)
// ──────────────────────────────────────────────────────────

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum ClientStatus {
  POTENTIAL
  ACTIVE
  PAST
  FAILED
}

model Client {
  id                String       @id @default(cuid())
  type              ClientType   @default(COMPANY)
  status            ClientStatus @default(POTENTIAL)

  // Company (B2B)
  companyName       String?
  ico               String?
  dic               String?
  icoOverride       Boolean      @default(false)

  // Individual (B2C)
  fullName          String?

  // Shared contact
  email             String?
  phone             String?
  addressStreet     String?
  addressCity       String?
  addressZip        String?
  addressCountry    String       @default("CZ")

  notes             String?
  defaultLanguage   UserLocale   @default(cs)
  preferredCurrency String       @default("CZK")

  // GDPR §24.2 — anonymization takes precedence when fiscal records require retention.
  anonymizedAt      DateTime?
  deletedAt         DateTime?

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  contactLogs       ContactLog[]
  customFieldValues CustomFieldValue[]
  jobs              Job[]
  calendarEvents    CalendarEvent[]
  documents         Document[]
  payments          Payment[]

  @@index([status])
  @@index([email])
  @@index([ico])
}

enum ContactLogType {
  PHONE
  EMAIL
  MEETING
  SITE_VISIT
  OTHER
}

model ContactLog {
  id         String         @id @default(cuid())
  clientId   String
  client     Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobId      String?
  job        Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  date       DateTime       @default(now())
  type       ContactLogType
  notes      String
  loggedById String
  loggedBy   User           @relation(fields: [loggedById], references: [id], onDelete: Restrict)
  createdAt  DateTime       @default(now())

  @@index([clientId, date])
  @@index([jobId])
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
}

model CustomFieldDef {
  id         String          @id @default(cuid())
  label      String          @unique
  fieldType  CustomFieldType
  archivedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  values     CustomFieldValue[]
}

model CustomFieldValue {
  id         String         @id @default(cuid())
  clientId   String
  client     Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fieldDefId String
  fieldDef   CustomFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)
  value      String

  @@unique([clientId, fieldDefId])
  @@index([fieldDefId])
}

// ──────────────────────────────────────────────────────────
// M4 — Jobs + Attachments (PRD §5)
// ──────────────────────────────────────────────────────────

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Job {
  id             String    @id @default(cuid())
  title          String
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  status         JobStatus @default(SCHEDULED)

  // Site address (overrides client billing address when set)
  siteStreet     String?
  siteCity       String?
  siteZip        String?
  siteCountry    String?

  scheduledStart DateTime?
  scheduledEnd   DateTime?
  notes          String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assignments    JobAssignment[]
  contactLogs    ContactLog[]
  attachments    Attachment[]
  calendarEvents CalendarEvent[]
  documents      Document[]
  expenses       Expense[]

  recurrenceRuleId String?
  recurrenceRule   RecurrenceRule? @relation("JobsFromRule", fields: [recurrenceRuleId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status, scheduledStart])
  @@index([recurrenceRuleId])
}

model JobAssignment {
  jobId      String
  userId     String
  job        Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([jobId, userId])
  @@index([userId])
}

enum AttachmentKind {
  IMAGE
  PDF
  OTHER
}

model Attachment {
  id           String         @id @default(cuid())
  jobId        String
  job          Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filename     String
  mimeType     String
  sizeBytes    Int
  kind         AttachmentKind
  path         String         // Relative /uploads/jobs/... path
  caption      String?
  uploadedById String
  uploadedBy   User           @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt    DateTime       @default(now())

  @@index([jobId, createdAt])
}

// ──────────────────────────────────────────────────────────
// M5 — Calendar events (PRD §6)
// ──────────────────────────────────────────────────────────

enum CalendarEventType {
  MEETING
  SITE_VISIT
  REMINDER
  OTHER
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  type        CalendarEventType @default(MEETING)
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean           @default(false)
  notes       String?
  completedAt DateTime?

  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?    @relation("CalendarEventAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User     @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startsAt])
  @@index([assigneeId, startsAt])
}

// ──────────────────────────────────────────────────────────
// M6 — Units + Item Templates (PRD §7, §8, §22.6)
// ──────────────────────────────────────────────────────────

enum TaxMode {
  NET    // "price is before tax"
  GROSS  // "price is after tax" (price already includes VAT)
}

model Unit {
  id         String    @id @default(cuid())
  name       String    @unique
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  itemTemplates ItemTemplate[]
}

model ItemTemplate {
  id                   String        @id @default(cuid())
  name                 String
  description          String?

  categoryId           String?
  category             ItemCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  unitId               String
  unit                 Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)

  // PRD §22.6: money 2dp, quantity 3dp, percent 2dp
  defaultQuantity      Decimal       @db.Decimal(12, 3) @default(1)
  defaultCost          Decimal?      @db.Decimal(12, 2)
  defaultMarkupPercent Decimal?      @db.Decimal(5, 2)
  defaultUnitPrice     Decimal       @db.Decimal(12, 2)

  defaultTaxRateId     String
  defaultTaxRate       TaxRate       @relation(fields: [defaultTaxRateId], references: [id], onDelete: Restrict)
  defaultTaxMode       TaxMode       @default(NET)

  archivedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([categoryId])
  @@index([archivedAt])
}

// ──────────────────────────────────────────────────────────
// M7 — Document templates (PRD §9)
// ──────────────────────────────────────────────────────────

enum DocumentType {
  QUOTE
  ADVANCE_INVOICE
  FINAL_INVOICE
  CREDIT_NOTE
}

model DocumentTemplate {
  id               String       @id @default(cuid())
  name             String
  type             DocumentType
  companyProfileId String?
  companyProfile   CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)

  accentColor      String       @default("#1d4ed8")
  fontChoice       String       @default("Roboto")
  headerPosition   String       @default("TOP")  // reserved for future layouts
  showLogo         Boolean      @default(true)
  showSignature    Boolean      @default(true)
  showQrPlatba     Boolean      @default(true)
  showReverseChargeNote Boolean  @default(true)
  customHeaderText String?
  customFooterText String?

  isDefault        Boolean      @default(false)
  archivedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([type, isDefault])

  documents         Document[]
}

// ──────────────────────────────────────────────────────────
// M8+ — Documents (Quotes, Advance Invoices, Final Invoices, Credit Notes)
// PRD §3, §8, §10–§13, §21.3
// ──────────────────────────────────────────────────────────

enum DocumentStatus {
  UNSENT                  // Draft, no number yet
  SENT                    // Issued (for quotes: waiting; for invoices: unpaid)
  ACCEPTED                // Quote only
  REJECTED                // Quote only
  EXPIRED                 // Quote only (auto when validUntil passed)
  PARTIALLY_PAID          // Invoice
  PAID                    // Invoice or credit note
  OVERDUE                 // Invoice (derived from dueDate)
  PAID_PENDING_COMPLETION // Advance invoice paid but linked job not COMPLETED
  APPLIED                 // Credit note applied to original
}

enum AdvanceAmountMode {
  PERCENT
  FIXED
}

model Document {
  id                 String         @id @default(cuid())
  type               DocumentType
  status             DocumentStatus @default(UNSENT)

  // Gapless numbering — assigned at UNSENT → SENT transition (PRD §3, §21.3)
  number             String?        // e.g. "Q-2026-0001"
  yearSeries         Int?
  numberSeq          Int?

  // Relations
  clientId           String
  client             Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  jobId              String?
  job                Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  companyProfileId   String
  companyProfile     CompanyProfile   @relation(fields: [companyProfileId], references: [id], onDelete: Restrict)
  documentTemplateId String
  documentTemplate   DocumentTemplate @relation(fields: [documentTemplateId], references: [id], onDelete: Restrict)
  createdById        String
  createdBy          User             @relation("DocumentCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // Money + currency (PRD §22.2)
  currency           String         @default("CZK")
  exchangeRateToCzk  Decimal        @db.Decimal(12, 6) @default(1)

  // Language the document itself is written in (PRD §22.1)
  locale             UserLocale     @default(cs)

  // Dates
  issueDate          DateTime
  taxPointDate       DateTime?      // Invoices; shown on PDF only when different from issue date
  dueDate            DateTime?      // Invoices
  validUntilDate     DateTime?      // Quotes

  // Toggles
  reverseCharge      Boolean        @default(false)

  // Document-level discount (PRD §8.1)
  documentDiscountPercent Decimal?  @db.Decimal(5, 2)
  documentDiscountAmount  Decimal?  @db.Decimal(12, 2)

  // Notes
  notesInternal      String?
  notesToClient      String?

  // Totals override flag (PRD §8.2 rule 7)
  totalsOverride     Boolean        @default(false)
  totalNetOverride   Decimal?       @db.Decimal(12, 2)
  totalTaxOverride   Decimal?       @db.Decimal(12, 2)
  totalGrossOverride Decimal?       @db.Decimal(12, 2)

  // Advance-invoice specifics (PRD §11)
  advanceAmountMode    AdvanceAmountMode?
  advanceAmountPercent Decimal?     @db.Decimal(5, 2)
  advanceAmountFixed   Decimal?     @db.Decimal(12, 2)
  sourceQuoteId        String?
  sourceQuote          Document?    @relation("QuoteToInvoice", fields: [sourceQuoteId], references: [id], onDelete: SetNull)
  derivedInvoices      Document[]   @relation("QuoteToInvoice")

  // Credit-note specifics (PRD §13)
  originalDocumentId String?
  originalDocument   Document?      @relation("DocumentCredits", fields: [originalDocumentId], references: [id], onDelete: SetNull)
  creditNotes        Document[]     @relation("DocumentCredits")
  creditReason       String?

  // Lifecycle timestamps
  sentAt             DateTime?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  expiredAt          DateTime?
  completedAt        DateTime?      // advance → job marked Completed
  paidAt             DateTime?

  // Soft-delete — only allowed while UNSENT (PRD §21.3)
  deletedAt          DateTime?

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  lineItems          DocumentLineItem[]
  pdfSnapshots       PdfSnapshot[]

  // M10: advances deducted on THIS final invoice
  advanceDeductions  AdvanceDeduction[] @relation("FinalInvoiceDeductions")
  // M10: final invoices deducting THIS advance
  deductedOn         AdvanceDeduction[] @relation("AdvanceDeducted")

  // M12: payment allocations to this document
  paymentAllocations PaymentAllocation[]

  // M14: recurrence rule that generated this document (if any)
  recurrenceRuleId   String?
  recurrenceRule     RecurrenceRule? @relation("DocumentsFromRule", fields: [recurrenceRuleId], references: [id], onDelete: SetNull)

  @@unique([type, yearSeries, numberSeq])
  @@index([clientId])
  @@index([jobId])
  @@index([status])
  @@index([issueDate])
  @@index([sourceQuoteId])
  @@index([originalDocumentId])
}

model DocumentLineItem {
  id                  String   @id @default(cuid())
  documentId          String
  document            Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  position            Int
  name                String
  description         String?
  quantity            Decimal  @db.Decimal(12, 3)
  unit                String
  unitPrice           Decimal  @db.Decimal(12, 2)
  taxRatePercent      Decimal  @db.Decimal(5, 2)
  taxMode             TaxMode  @default(NET)
  lineDiscountPercent Decimal? @db.Decimal(5, 2)
  lineDiscountAmount  Decimal? @db.Decimal(12, 2)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([documentId, position])
  @@index([documentId])
}

// Gapless numbering state (PRD §21.3). One row per (type, year).
// Allocation happens inside a transaction; atomically bumps nextSeq.
model NumberSeries {
  type      DocumentType
  year      Int
  nextSeq   Int          @default(1)
  updatedAt DateTime     @updatedAt

  @@id([type, year])
}

// M10 — PRD §12: advances deducted on a final invoice. Join table so one
// final invoice can deduct multiple advances and one advance could (in
// principle) be applied across multiple finals, though the UI prevents it.
model AdvanceDeduction {
  finalInvoiceId String
  finalInvoice   Document @relation("FinalInvoiceDeductions", fields: [finalInvoiceId], references: [id], onDelete: Cascade)
  advanceId      String
  advance        Document @relation("AdvanceDeducted",       fields: [advanceId],      references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())

  @@id([finalInvoiceId, advanceId])
  @@index([advanceId])
}

// Frozen PDF archive (PRD §9.5). Generated when document transitions to SENT.
// Retained 10 years per Czech law. Edits update the data but not the snapshot.
model PdfSnapshot {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  filePath    String
  contentHash String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  @@index([documentId])
}

// ──────────────────────────────────────────────────────────
// M12 — Payments + split allocation (PRD §14)
// ──────────────────────────────────────────────────────────

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  OTHER
}

model Payment {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  date        DateTime      @default(now())
  method      PaymentMethod @default(BANK_TRANSFER)
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("CZK")
  reference   String?
  notes       String?
  loggedById  String
  loggedBy    User          @relation(fields: [loggedById], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  allocations PaymentAllocation[]

  @@index([clientId, date])
}

// Split-payment support (PRD §14.2): one Payment spreads across many invoices.
model PaymentAllocation {
  id         String   @id @default(cuid())
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Restrict)
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  @@index([paymentId])
  @@index([documentId])
}

// ──────────────────────────────────────────────────────────
// M13 — Expenses (PRD §15)
// ──────────────────────────────────────────────────────────

model ExpenseCategory {
  id         String    @id @default(cuid())
  name       String    @unique
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  expenses   Expense[]
}

enum ExpensePaymentMethod {
  BANK
  CASH
}

model Expense {
  id             String          @id @default(cuid())
  date           DateTime
  categoryId     String
  category       ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  supplier       String?
  description    String

  netAmount      Decimal         @db.Decimal(12, 2)
  vatRatePercent Decimal         @db.Decimal(5, 2)  // 0 / 12 / 21 / 0 + reverseCharge
  vatAmount      Decimal         @db.Decimal(12, 2)
  totalAmount    Decimal         @db.Decimal(12, 2)
  currency       String          @default("CZK")
  reverseCharge  Boolean         @default(false)

  paymentMethod  ExpensePaymentMethod @default(BANK)

  receiptPath    String?

  jobId          String?
  job            Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)

  taxDeductible  Boolean         @default(true)
  notes          String?

  createdById    String
  createdBy      User            @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: Restrict)

  recurrenceRuleId String?
  recurrenceRule   RecurrenceRule? @relation("ExpensesFromRule", fields: [recurrenceRuleId], references: [id], onDelete: SetNull)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([jobId])
  @@index([recurrenceRuleId])
}

// ──────────────────────────────────────────────────────────
// M14 — Recurring items (PRD §16)
// ──────────────────────────────────────────────────────────

enum RecurrenceTarget {
  JOB
  EXPENSE
  INVOICE
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

model RecurrenceRule {
  id            String              @id @default(cuid())
  name          String
  targetKind    RecurrenceTarget
  frequency     RecurrenceFrequency
  customDays    Int?                // required when frequency = CUSTOM
  startDate     DateTime
  endDate       DateTime?
  daysInAdvance Int                 @default(0)
  autoGenerate  Boolean             @default(true)

  // Next scheduled fire time (advances after each run).
  nextRunAt     DateTime

  // Operational flags
  pausedAt      DateTime?
  lastRunAt     DateTime?
  lastError     String?

  // JSON template payload — schema depends on targetKind.
  // See src/lib/recurrence-payloads.ts for each variant.
  payload       Json

  createdById   String
  createdBy     User                @relation("RecurrenceCreator", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  jobs          Job[]               @relation("JobsFromRule")
  expenses      Expense[]           @relation("ExpensesFromRule")
  documents     Document[]          @relation("DocumentsFromRule")

  @@index([nextRunAt, pausedAt])
  @@index([targetKind])
}

// Rate-limit login attempts by IP (PRD §23 brute-force protection).
model LoginAttempt {
  id        String   @id @default(cuid())
  ipHash    String
  email     String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}
